{
  "name": "andrewdyer/slim-api-kernel",
  "description": "Tools for building structured and predictable JSON APIs with Slim Framework 4 using an Action–Domain–Responder style approach.",
  "type": "library",
  "autoload": {
    "psr-4": {
      "Slim\\ApiKernel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Slim\\ApiKernel\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "psr/http-message": "^2.0",
    "slim/slim": "^4.15"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpunit/phpunit": "^10.5",
    "slim/psr7": "^1.8"
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
